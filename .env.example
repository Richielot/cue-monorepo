# Supabase (cloud — use these for production or Supabase-hosted dev)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Docker: postgresql://postgres:postgres@db:5432/cue_dev)
# Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cue_dev

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
