# Supabase (cloud — use these for production or Supabase-hosted dev)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (Docker: postgresql://postgres:postgres@db:5432/cue_dev)
# Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cue_dev

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Path C gate — keep "false" in production during waitlist phase.
# Flip to "true" once the NIS2 core is ready for real customer onboarding.
NEXT_PUBLIC_SIGNUPS_OPEN=false

# Salt used when hashing IPs on the /api/waitlist endpoint.
# Generate with: openssl rand -hex 32
WAITLIST_IP_SALT=change-me-in-production
